; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="AIKIOPA"
config/description="COSC3072 Games Studio 1 Project, Team 04, RMIT Vietnam 2026."
run/main_scene="uid://c3ymdt5ihd458"
config/custom_user_dir_name="AIKIOPA"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://dqp3lnsxh5fw"

[autoload]

Global="*uid://1e7omhauptu1"
GameplayEventBus="*uid://bvbx608cejmwp"
UIEventBus="*uid://ec3r0dickbin"
Math="*uid://b6l5brx5akrvh"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/mode.editor=0

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "red",
"res://resources/": "orange",
"res://scenes/": "blue",
"res://scripts/": "purple",
"res://shaders/": "green",
"res://tests/": "pink"
}

